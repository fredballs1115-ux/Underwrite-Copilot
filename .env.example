# ──────────────────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in real values:
#     cp .env.example .env.local
# ".env.local" is gitignored, so your secrets never get committed.
# ──────────────────────────────────────────────────────────────────────────

# Claude (Anthropic) — SERVER-SIDE ONLY. Get a key at https://console.anthropic.com.
# Notice there is no NEXT_PUBLIC_ prefix: that keeps it out of the browser.
ANTHROPIC_API_KEY=

# Supabase — from your project's Project Settings → API.
# The URL and the anon key are safe to expose to the browser, which is why they
# use the NEXT_PUBLIC_ prefix (Next.js only ships NEXT_PUBLIC_ vars to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The service-role key is a powerful admin key — SERVER-SIDE ONLY. Never give it
# a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# The app's public URL (used for links and auth redirects). Local default below.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — subscription billing (Pro plan). All SERVER-SIDE ONLY (no NEXT_PUBLIC_).
#   STRIPE_SECRET_KEY     — Developers → API keys (use the test key while testing).
#   STRIPE_PRICE_ID       — the recurring Price for the Pro plan ($79/mo). Create a
#                           Product + recurring Price in Stripe, then paste its
#                           price_… id here.
#   STRIPE_WEBHOOK_SECRET — from the webhook endpoint you add for /api/stripe/webhook
#                           (Developers → Webhooks). With the Stripe CLI locally:
#                           `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
