# ──────────────────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in real values:
#     cp .env.example .env.local
# ".env.local" is gitignored, so your secrets never get committed.
# ──────────────────────────────────────────────────────────────────────────

# Claude (Anthropic) — SERVER-SIDE ONLY. Get a key at https://console.anthropic.com.
# Notice there is no NEXT_PUBLIC_ prefix: that keeps it out of the browser.
ANTHROPIC_API_KEY=

# Supabase — from your project's Project Settings → API.
# The URL and the anon key are safe to expose to the browser, which is why they
# use the NEXT_PUBLIC_ prefix (Next.js only ships NEXT_PUBLIC_ vars to the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The service-role key is a powerful admin key — SERVER-SIDE ONLY. Never give it
# a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# The app's public URL (used for links and auth redirects). Local default below.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — subscription billing. All SERVER-SIDE ONLY (no NEXT_PUBLIC_).
#   STRIPE_SECRET_KEY        — Developers → API keys (use the test key while testing).
#   STRIPE_PRICE_ID          — recurring Price for the Pro plan ($29.99/mo).
#   STRIPE_TEAM_PRICE_ID     — recurring Price for the Team BASE ($49.99/mo, covers
#                              the owner; billed at quantity 1).
#   STRIPE_TEAM_SEAT_PRICE_ID— recurring Price for each ADDED member ($9.99/mo;
#                              quantity = members beyond the owner). Create it as a
#                              plain flat recurring price on the Team product.
#   STRIPE_WEBHOOK_SECRET    — from the webhook endpoint you add for /api/stripe/webhook
#                              (Developers → Webhooks). With the Stripe CLI locally:
#                              `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# The webhook verifies every subscription's price ids against these three vars
# and alerts (log + email) instead of processing anything it doesn't recognize.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_TEAM_SEAT_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Resend — analysis-ready emails + billing alerts. SERVER-SIDE ONLY. Optional:
# with no key the email features stay silently off.
#   RESEND_API_KEY       — from https://resend.com (API Keys).
#   RESEND_FROM          — a sender on your verified domain, e.g.
#                          "Underwrite Copilot <notify@yourdomain.com>". Falls back
#                          to Resend's onboarding sender until the domain is set up.
#   BILLING_ALERT_EMAIL  — where webhook price-mismatch alerts go (defaults to the
#                          support inbox).
RESEND_API_KEY=
RESEND_FROM=
BILLING_ALERT_EMAIL=
